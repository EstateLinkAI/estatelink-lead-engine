POSTGRES_USER=estatelink
POSTGRES_PASSWORD=change_me
POSTGRES_DB=estatelink
DATABASE_URL=postgres://estatelink:change_me@localhost:5432/estatelink?sslmode=disable
JWT_SECRET=replace_with_a_long_random_secret
ACCESS_TOKEN_TTL=24h
REFRESH_TOKEN_TTL=168h

# Import safety limits - bound memory usage for bulk imports.
# See internal/application/importlistings.UseCase and
# internal/transport/http.ImportHandler.
MAX_IMPORT_ROWS=5000
MAX_REQUEST_BODY_BYTES=25000000
IMPORT_WORKERS=4
